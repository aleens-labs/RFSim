# Copy this file to deploy/.env and replace the placeholder values before deployment.

# Postgres
POSTGRES_DB=ew_sim
POSTGRES_USER=ew_sim
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD

# Backend auth / encryption
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_JWT_SECRET
AI_CONFIG_SECRET=REPLACE_WITH_A_LONG_RANDOM_AI_CONFIG_SECRET

# Public app origin used by the backend for auth / CORS
APP_ORIGIN=https://YOUR_DOMAIN

# Database connection tuning
DATABASE_SSL=false
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=10000
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=10000

# Analytics retention
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_PRUNE_INTERVAL_MS=21600000

# Frontend runtime config
EW_SIM_API_BASE_URL=/api
CESIUM_ION_DEFAULT_TOKEN=
